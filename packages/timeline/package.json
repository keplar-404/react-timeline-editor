    "@types/react-virtualized": "^9.21.14",
    "framework-utils": "^1.1.0",
    "interactjs": "^1.10.11",
    "react-virtualized": "^9.22.3"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.177",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
