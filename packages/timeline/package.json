      "style": "./dist/react-timeline-editor.css",
      "default": "./dist/react-timeline-editor.css"
    }
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
